{
  "definitions": [
    {
      "title": "Hero",
      "id": "hero",
      "model": "hero",
      "plugins": {
        "da": {
          "name": "hero",
          "rows": 2,
          "columns": 1,
          "fields": [
            { "name": "image", "selector": "div:nth-child(1)>div>picture>img[src]" },
            { "name": "imageAlt", "selector": "div:nth-child(1)>div>picture>img[alt]" },
            { "name": "heading", "selector": "div:nth-child(2)>div>h1" }
          ]
        }
      }
    },
    {
      "title": "Hero (Video)",
      "id": "hero-video",
      "model": "hero-video",
      "plugins": {
        "da": {
          "name": "hero",
          "classes": "video",
          "rows": 3,
          "columns": 1,
          "fields": [
            { "name": "darkVideo", "selector": "div:nth-child(1)>div>a[href*=\".mp4\"]" },
            { "name": "lightVideo", "selector": "div:nth-child(2)>div>a[href*=\".mp4\"]" },
            { "name": "heading", "selector": "div:nth-child(3)>div>h1" }
          ]
        }
      }
    }
  ],
